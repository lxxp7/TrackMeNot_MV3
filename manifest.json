{
  "author": "TrackMeNot",
  "background": {
    "service_worker": "background_wrapper.js"
  },
  "action": {
    "default_icon": "tmn.png",
    "default_popup": "tmn_menu.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["tmn_search.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "description": "Protect against data profiling by search engines",
  "icons": {
    "16": "icon16.png",
    "48": "icon32.png"
  },
  "manifest_version": 3,
  "name": "TrackMeNot",
  "options_ui": {
    "page": "options.html"
  },
  "permissions": ["tabs", "cookies", "webNavigation", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "version": "0.10.46"
}
